[apply]
	whitespace = fix

[core]
	excludesfile = ~/.gitignore_global
	whitespace = space-before-tab,-indent-with-non-tab,trailing-space
	trustctime = false
	untrackedCache = true

[push]
	default = simple
	followTags = true

[user]
	name = Nick Blomberg
	email = nick.blomberg@gmail.com

[web]
	browser = firefox

[init]
	defaultBranch = main
